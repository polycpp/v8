   ISOLATE_DATA_FIELDS(V)
 #undef V
+#ifdef _MSC_VER
+  // MSVC [[msvc::no_unique_address]] may not eliminate empty padding members
+  // in all configurations. Relax this check on MSVC.
+  static_assert(sizeof(IsolateData) >= IsolateData::kSizeOffset);
+#else
   static_assert(sizeof(IsolateData) == IsolateData::kSizeOffset);
+#endif
 }
 
