@@ -0,0 +1,217 @@
+// Copyright 2024 the V8 project authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// Minimal no-op inspector stub so that d8 and tests can link without
+// the full inspector protocol generator output.
+
+#include "include/v8-inspector.h"
+
+#include <cstring>
+#include <vector>
+
+// Minimal definitions for generated protocol types that unique_ptr needs
+// to be complete. These are normally generated by the inspector protocol
+// generator but we don't run it.
+namespace v8_inspector {
+namespace protocol {
+namespace Runtime {
+namespace API {
+class RemoteObject {
+ public:
+  virtual ~RemoteObject() = default;
+};
+}  // namespace API
+}  // namespace Runtime
+namespace Debugger {
+namespace API {
+class SearchMatch {
+ public:
+  virtual ~SearchMatch() = default;
+};
+}  // namespace API
+}  // namespace Debugger
+namespace Schema {
+namespace API {
+class Domain {
+ public:
+  virtual ~Domain() = default;
+};
+}  // namespace API
+}  // namespace Schema
+}  // namespace protocol
+
+// ---------------------------------------------------------------------------
+// StringBuffer stub
+// ---------------------------------------------------------------------------
+namespace {
+class StubStringBuffer : public StringBuffer {
+ public:
+  StringView string() const override { return StringView(); }
+};
+}  // namespace
+
+std::unique_ptr<StringBuffer> StringBuffer::create(StringView) {
+  return std::make_unique<StubStringBuffer>();
+}
+
+// ---------------------------------------------------------------------------
+// V8ContextInfo
+// ---------------------------------------------------------------------------
+int V8ContextInfo::executionContextId(v8::Local<v8::Context>) { return 0; }
+
+// ---------------------------------------------------------------------------
+// V8DebuggerId
+// ---------------------------------------------------------------------------
+V8DebuggerId::V8DebuggerId(std::pair<int64_t, int64_t>) {}
+
+std::unique_ptr<StringBuffer> V8DebuggerId::toString() const {
+  return std::make_unique<StubStringBuffer>();
+}
+
+bool V8DebuggerId::isValid() const { return false; }
+
+std::pair<int64_t, int64_t> V8DebuggerId::pair() const { return {0, 0}; }
+
+// ---------------------------------------------------------------------------
+// V8StackTraceId
+// ---------------------------------------------------------------------------
+V8StackTraceId::V8StackTraceId() : id(0), debugger_id({0, 0}), should_pause(false) {}
+
+V8StackTraceId::V8StackTraceId(uintptr_t id,
+                               const std::pair<int64_t, int64_t> debugger_id)
+    : id(id), debugger_id(debugger_id), should_pause(false) {}
+
+V8StackTraceId::V8StackTraceId(uintptr_t id,
+                               const std::pair<int64_t, int64_t> debugger_id,
+                               bool should_pause)
+    : id(id), debugger_id(debugger_id), should_pause(should_pause) {}
+
+V8StackTraceId::V8StackTraceId(StringView)
+    : id(0), debugger_id({0, 0}), should_pause(false) {}
+
+bool V8StackTraceId::IsInvalid() const { return id == 0; }
+
+std::unique_ptr<StringBuffer> V8StackTraceId::ToString() {
+  return std::make_unique<StubStringBuffer>();
+}
+
+// ---------------------------------------------------------------------------
+// V8InspectorSession::canDispatchMethod  (static, not virtual)
+// ---------------------------------------------------------------------------
+bool V8InspectorSession::canDispatchMethod(StringView) { return false; }
+
+// ---------------------------------------------------------------------------
+// Stub V8InspectorSession implementation
+// ---------------------------------------------------------------------------
+namespace {
+class StubInspectorSession : public V8InspectorSession {
+ public:
+  void addInspectedObject(std::unique_ptr<Inspectable>) override {}
+  void dispatchProtocolMessage(StringView) override {}
+  std::vector<uint8_t> state() override { return {}; }
+  std::vector<std::unique_ptr<protocol::Schema::API::Domain>>
+  supportedDomains() override {
+    return {};
+  }
+  void schedulePauseOnNextStatement(StringView, StringView) override {}
+  void cancelPauseOnNextStatement() override {}
+  void breakProgram(StringView, StringView) override {}
+  void setSkipAllPauses(bool) override {}
+  void resume(bool) override {}
+  void stepOver() override {}
+  std::vector<std::unique_ptr<protocol::Debugger::API::SearchMatch>>
+  searchInTextByLines(StringView, StringView, bool, bool) override {
+    return {};
+  }
+  std::unique_ptr<protocol::Runtime::API::RemoteObject> wrapObject(
+      v8::Local<v8::Context>, v8::Local<v8::Value>, StringView,
+      bool) override {
+    return nullptr;
+  }
+  bool unwrapObject(std::unique_ptr<StringBuffer>*, StringView,
+                    v8::Local<v8::Value>*, v8::Local<v8::Context>*,
+                    std::unique_ptr<StringBuffer>*) override {
+    return false;
+  }
+  void releaseObjectGroup(StringView) override {}
+  void triggerPreciseCoverageDeltaUpdate(StringView) override {}
+  EvaluateResult evaluate(v8::Local<v8::Context>, StringView,
+                          bool) override {
+    return {EvaluateResult::ResultType::kNotRun, {}};
+  }
+  void stop() override {}
+};
+}  // namespace
+
+// ---------------------------------------------------------------------------
+// Stub V8Inspector implementation + factory
+// ---------------------------------------------------------------------------
+namespace {
+class StubInspector : public V8Inspector {
+ public:
+  StubInspector(v8::Isolate* isolate, V8InspectorClient*) : isolate_(isolate) {}
+
+  void contextCreated(const V8ContextInfo&) override {}
+  void contextDestroyed(v8::Local<v8::Context>) override {}
+  void resetContextGroup(int) override {}
+  v8::MaybeLocal<v8::Context> contextById(int) override {
+    return v8::MaybeLocal<v8::Context>();
+  }
+  V8DebuggerId uniqueDebuggerId(int) override { return V8DebuggerId(); }
+  uint64_t isolateId() override { return 0; }
+
+  void idleStarted() override {}
+  void idleFinished() override {}
+
+  void asyncTaskScheduled(StringView, void*, bool) override {}
+  void asyncTaskCanceled(void*) override {}
+  void asyncTaskStarted(void*) override {}
+  void asyncTaskFinished(void*) override {}
+  void allAsyncTasksCanceled() override {}
+
+  V8StackTraceId storeCurrentStackTrace(StringView) override {
+    return V8StackTraceId();
+  }
+  void externalAsyncTaskStarted(const V8StackTraceId&) override {}
+  void externalAsyncTaskFinished(const V8StackTraceId&) override {}
+
+  unsigned exceptionThrown(v8::Local<v8::Context>, StringView,
+                           v8::Local<v8::Value>, StringView, StringView,
+                           unsigned, unsigned, std::unique_ptr<V8StackTrace>,
+                           int) override {
+    return 0;
+  }
+  void exceptionRevoked(v8::Local<v8::Context>, unsigned, StringView) override {
+  }
+  bool associateExceptionData(v8::Local<v8::Context>, v8::Local<v8::Value>,
+                              v8::Local<v8::Name>,
+                              v8::Local<v8::Value>) override {
+    return false;
+  }
+
+  std::unique_ptr<V8InspectorSession> connect(
+      int, Channel*, StringView, ClientTrustLevel,
+      SessionPauseState) override {
+    return std::make_unique<StubInspectorSession>();
+  }
+
+  std::unique_ptr<V8StackTrace> createStackTrace(
+      v8::Local<v8::StackTrace>) override {
+    return nullptr;
+  }
+  std::unique_ptr<V8StackTrace> captureStackTrace(bool) override {
+    return nullptr;
+  }
+
+ private:
+  v8::Isolate* isolate_;
+};
+}  // namespace
+
+std::unique_ptr<V8Inspector> V8Inspector::create(v8::Isolate* isolate,
+                                                 V8InspectorClient* client) {
+  return std::make_unique<StubInspector>(isolate, client);
+}
+
+}  // namespace v8_inspector
