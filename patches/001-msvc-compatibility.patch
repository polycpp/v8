 #include "src/sandbox/trusted-pointer-table.h"
 #include "src/utils/utils.h"
+
+// MSVC does not allow zero-length arrays (error C2229).
+// V8 uses zero-length arrays with V8_NO_UNIQUE_ADDRESS for alignment padding.
+// On MSVC, we use a template that becomes an empty class when N==0,
+// combined with [[msvc::no_unique_address]] to occupy zero bytes.
+#ifdef _MSC_VER
+template <size_t N>
+struct V8MsvcPadding {
+  uint8_t data[N];
+};
+template <>
+struct V8MsvcPadding<0> {};
+static_assert(sizeof(V8MsvcPadding<0>) == 1);  // Empty class has size 1
+#endif
 #include "testing/gtest/include/gtest/gtest_prod.h"  // nogncheck
 
