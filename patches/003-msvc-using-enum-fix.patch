+// MSVC workaround: Helper to filter a single operand (avoids generic lambda
+// template call syntax that MSVC doesn't support).
+template <typename Operands, std::size_t I>
+consteval auto FilterOperandForDispatch() {
+  using Operand = typename Operands::Operand;
+  constexpr auto id = static_cast<Operand>(I);
+  if constexpr (Operands::Type(id) == ReBcOpType::kPadding1 ||
+                Operands::Type(id) == ReBcOpType::kPadding2) {
+    return std::tuple<>();
+  } else {
+    return std::tuple(std::integral_constant<Operand, id>{});
+  }
+}
+
+template <typename Operands, std::size_t... Is>
+consteval auto FilterOperandsImpl(std::index_sequence<Is...>) {
+  return std::tuple_cat(FilterOperandForDispatch<Operands, Is>()...);
+}
+
+// MSVC workaround: Use tuple_element_t instead of std::apply with
+// fold expression on integral_constant pack.
+template <typename Func, typename Tuple, std::size_t... Is>
+void ApplyOperandPack(Func&& func, const Tuple&,
+                      std::index_sequence<Is...>) {
+  func.template
+      operator()<std::tuple_element_t<Is, Tuple>::value...>();
+}
+
 // Calls |func| passing all operand ids (except paddings) as a template
 // parameter pack.
 template <typename Operands, typename Func>
 void DispatchByOperand(Func&& func) {
   // Filter padding operands.
-  auto filtered_ops = []<std::size_t... Is>(std::index_sequence<Is...>) {
-    return std::tuple_cat([]<std::size_t I>() {
-      using Operand = typename Operands::Operand;
-      constexpr auto id = static_cast<Operand>(I);
-      if constexpr (Operands::Type(id) == ReBcOpType::kPadding1 ||
-                    Operands::Type(id) == ReBcOpType::kPadding2) {
-        return std::tuple<>();
-      } else {
-        return std::tuple(std::integral_constant<Operand, id>{});
-      }
-    }.template operator()<Is>()...);
-  }(std::make_index_sequence<Operands::kCount>{});
-
-  std::apply([&](auto... ops) { func.template operator()<ops.value...>(); },
-             filtered_ops);
+  constexpr auto filtered_ops =
+      FilterOperandsImpl<Operands>(
+          std::make_index_sequence<Operands::kCount>{});
+  using FilteredTuple = decltype(filtered_ops);
+  ApplyOperandPack(
+      std::forward<Func>(func), filtered_ops,
+      std::make_index_sequence<std::tuple_size_v<FilteredTuple>>{});
 }
 
