diff --git a/src/compiler/turboshaft/turbolev-stub-ia32.cc b/src/compiler/turboshaft/turbolev-stub-ia32.cc
new file mode 100644
index 00000000..09ab5bd3
--- /dev/null
+++ b/src/compiler/turboshaft/turbolev-stub-ia32.cc
@@ -0,0 +1,19 @@
+// Stub for ia32: TurboLev (Maglev graph building for Turboshaft) is not
+// supported on ia32 because there is no Maglev ia32 backend.
+// This provides the minimal symbols needed to link the pipeline.
+
+#include "src/compiler/turboshaft/turbolev-graph-builder.h"
+
+#include "src/codegen/bailout-reason.h"
+#include "src/compiler/linkage.h"
+#include "src/compiler/turboshaft/phase.h"
+
+namespace v8::internal::compiler::turboshaft {
+
+std::optional<BailoutReason> TurbolevGraphBuildingPhase::Run(
+    PipelineData* data, Zone* temp_zone, Linkage* linkage) {
+  // Maglev backend not available on ia32.
+  return BailoutReason::kNoReason;
+}
+
+}  // namespace v8::internal::compiler::turboshaft
diff --git a/src/heap/base/asm/ia32/push_registers_masm.asm b/src/heap/base/asm/ia32/push_registers_masm.asm
